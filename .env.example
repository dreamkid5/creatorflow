# CreatorFlow app environment.
# Copy this file to .env in this same folder, fill in one voice key, and run npm run dev.
# Everything here is optional. The app works with no keys using the free on device voice.

# Premium voice for the Auto Video page. Set ONE of these. The app picks the
# provider automatically and keeps the key server side, never in the browser.

# Local voice server, free and no card, running on your machine.
# Start it in the voice-server folder, then set this.
# LOCAL_TTS_URL=http://localhost:5111

# ElevenLabs, top quality, no card, small free tier
ELEVENLABS_API_KEY=

# Google Cloud Text to Speech, large free tier, card for verification only
GOOGLE_TTS_KEY=

# Azure Speech, large free tier, card for verification only
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
