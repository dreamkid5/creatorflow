# CreatorFlow worker environment.
# Copy this file to .env in the worker folder, fill in what you use, then run:
#   npm run now      start immediately and keep rendering as you drop batches
#   npm run once     process the current batch once and exit
# Everything is optional. With no keys, videos render with motion and music only.

# ----- Voice, set ONE option -----
# Local voice server, free and no card. Start it in the voice-server folder.
# LOCAL_TTS_URL=http://localhost:5111

# Azure Speech, about 500k characters a month free, card for verification only
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
CF_AZURE_VOICE=en-US-GuyNeural

# Google Cloud Text to Speech, about 1M characters a month free
# GOOGLE_TTS_KEY=
# CF_GOOGLE_VOICE=en-US-Neural2-J

# ElevenLabs, top quality, no card, small free tier
# ELEVENLABS_API_KEY=
# CF_ELEVEN_VOICE=VR6AewLTigWG4xSOukaG

# ----- Rendering -----
CF_STYLE=watercolor
CF_SCENE_SECONDS=4
CF_INTERVAL=60

# ----- YouTube auto upload, optional -----
# YT_CLIENT_ID=
# YT_CLIENT_SECRET=
# YT_REFRESH_TOKEN=
# CF_YT_PRIVACY=unlisted
